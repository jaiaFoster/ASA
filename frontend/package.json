{
  "name": "asa-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit -p tsconfig.app.json && vite build",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit -p tsconfig.app.json --pretty false",
    "test": "vitest",
    "generate:api": "openapi --input src/api/openapi.json --output src/api/generated --client fetch && perl -0pi -e 's/\\n\\n\\z/\\n/' src/api/generated/models/*.ts"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "9.16.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@typescript-eslint/eslint-plugin": "8.18.0",
    "@typescript-eslint/parser": "8.18.0",
    "@vitejs/plugin-react": "5.1.4",
    "eslint": "9.39.5",
    "eslint-plugin-react-hooks": "5.1.0",
    "eslint-plugin-react-refresh": "0.4.16",
    "jsdom": "25.0.1",
    "openapi-typescript-codegen": "0.29.0",
    "typescript": "5.7.2",
    "vite": "7.3.6",
    "vitest": "4.1.0"
  }
}
